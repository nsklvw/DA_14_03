set search_path to lessons_database;

задача 1. количество заказов каждого клиента

select 
	customer_id,
	count(order_id) as cnt
from orders
group by customer_id;

задача 2. сумма продаж по заказам

select 
	order_id,
	(quantity * unit_price) ordsum
from order_items;

задача 3. общая сумма продаж по товарам

select 
	product_id,
	sum(quantity * unit_price) ordsum
from order_items
group by product_id;

задача 4. общая сумма продаж по товарам 
	
select 
	t2.product_name,
	t2.list_price,
	sum(t1.quantity * t1.unit_price) ordsum
from order_items as t1
join products as t2
on t1.product_id = t2.product_id
group by t2.product_name, t2.list_price;

задача 5. продажи каждого продавца

select 
	t1.salesman_id, 
	t2.employee_id 
	from orders as t1
join employees as t2
on t1.salesman_id = t2.employee_id;

select 
	t3.first_name,
	t3.last_name,
	t3.job_title,
	sum(t1.quantity * t1.unit_price) ordsum
from order_items as t1
join orders as t2
on t1.order_id = t2.order_id
join employees as t3
on t2.salesman_id = t3.employee_id
group by 
	t3.first_name,
	t3.last_name,
	t3.job_title;

задача 6. общая стоимость товаров на складе 

select 
	t1.warehouse_id,
	sum(t1.quantity * t2.standard_cost)
from inventories as t1
join products as t2
on t1.product_id = t2.product_id
group by t1.warehouse_id;







